#!/usr/bin/env bash
set -euo pipefail

# Get staged Swift files (excluding deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=d -- '*.swift')

if [ -z "$staged_files" ]; then
    exit 0
fi

echo "Running pre-commit hooks on staged Swift files..."

# --- SwiftFormat ---
if command -v swiftformat &>/dev/null; then
    echo "-> swiftformat"
    echo "$staged_files" | xargs swiftformat --lint --quiet 2>&1 || {
        echo ""
        echo "SwiftFormat violations found. Run 'swiftformat .' to fix them."
        exit 1
    }
else
    echo "warning: swiftformat not installed, skipping format check"
fi

# --- SwiftLint (via SPM plugin, version locked in Package.resolved) ---
echo "-> swiftlint"
swift package plugin --allow-writing-to-package-directory swiftlint lint --strict -- "$staged_files" 2>&1 || {
    echo ""
    echo "SwiftLint violations found. Fix them before committing."
    exit 1
}

echo "Pre-commit checks passed."
